# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APP_ID=your-discord-application-id
# Optional but recommended to register commands quickly in one server
DISCORD_GUILD_ID=your-discord-guild-id

# ChatOps worker settings
CHATOPS_WORKDIR=/absolute/path/to/this/repo
CHATOPS_ALLOWED_REPOS=owner/private-repo
CHATOPS_QUEUE_CAPACITY=64
CHATOPS_MAX_LOG_LINES=120

# Git/build/deploy settings used by scripts/chatops_run_task.sh
CHATOPS_BASE_BRANCH=main
CHATOPS_TEST_CMD="go test ./..."
CHATOPS_BUILD_CMD="make wasm"
# Optional: command that prints preview URL on stdout (last line is used)
# When developing in a private repo, this script can publish private docs/ to this public repo's Pages.
CHATOPS_PREVIEW_CMD="/Users/ichibankunio/go/src/github.com/ichibankunio/mdmgde-host/scripts/deploy_preview_to_pages.sh"
# Path to this public repository (defaults to script repository)
CHATOPS_PUBLIC_REPO_DIR="/Users/ichibankunio/go/src/github.com/ichibankunio/mdmgde-host"
# Optional override for preview root directory in public repo
# CHATOPS_PREVIEW_ROOT_DIR="docs/previews"
# Optional: used by /preview command
CHATOPS_PREVIEW_URL_TEMPLATE="https://ichibankunio.github.io/mobile-game-template/previews/{branch_slug}/"

# scripts/chatops_merge_branch.sh
CHATOPS_DELETE_BRANCH=false

# scripts/chatops_discard_branch.sh
# When /discard runs, remove remote task branch too.
CHATOPS_DISCARD_DELETE_REMOTE=true
